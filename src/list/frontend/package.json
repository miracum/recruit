{
  "name": "list",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "vite build",
    "format": "oxfmt -c ../.oxfmtrc.json --write src tests/unit",
    "format:check": "oxfmt -c ../.oxfmtrc.json --check src tests/unit",
    "lint": "npm run lint:oxlint && npm run lint:eslint",
    "lint:eslint": "eslint src tests/unit",
    "lint:oxlint": "oxlint -c .oxlintrc.json src tests/unit",
    "serve": "vite",
    "test:e2e": "npm --prefix tests/e2e test",
    "test:unit": "vitest run --coverage"
  },
  "dependencies": {
    "@dsb-norge/vue-keycloak-js": "3.0.8",
    "@fortawesome/fontawesome-svg-core": "7.3.1",
    "@fortawesome/free-solid-svg-icons": "7.3.1",
    "@fortawesome/vue-fontawesome": "3.3.0",
    "axios": "1.18.1",
    "buefy": "3.0.8",
    "bulma": "1.0.4",
    "csv-stringify": "6.8.0",
    "fhirclient": "2.6.3",
    "fhirpath": "4.11.0",
    "vue": "3.5.39",
    "vue-router": "5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@vitejs/plugin-vue": "6.0.7",
    "@vitest/coverage-v8": "4.1.9",
    "@vitest/eslint-plugin": "1.6.21",
    "@vue/test-utils": "2.4.11",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-oxlint": "1.72.0",
    "eslint-plugin-vue": "10.9.2",
    "esbuild": "0.28.1",
    "globals": "17.7.0",
    "js-yaml": "5.2.1",
    "jsdom": "29.1.1",
    "oxfmt": "0.57.0",
    "oxlint": "1.72.0",
    "sass": "1.101.0",
    "vite": "8.1.3",
    "vitest": "4.1.9",
    "pino": "10.3.1"
  }
}
